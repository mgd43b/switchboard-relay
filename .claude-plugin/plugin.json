  "license": "MIT",
  "keywords": [
    "mcp",
    "messaging",
    "inter-session",
    "claude-code",
    "agents"
  ],
  "mcpServers": {
    "switchboard-relay": {
      "command": "uvx",
      "args": [
        "switchboard-relay"
      ]
    }
  }
}
